# Tetradkata Theme Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# FTP Configuration
FTP_HOST=your-ftp-server.com
FTP_USER=your-ftp-username
FTP_PASSWORD=your-ftp-password
FTP_PORT=21
FTP_SECURE=false
FTP_REMOTE_DIR=/htdocs/wp-content/themes/tetradkata-theme/

# Site Configuration
SITE_URL=https://your-domain.com
WP_HOME=https://your-domain.com
WP_SITEURL=https://your-domain.com

# Development/Production
ENVIRONMENT=development
WP_DEBUG=false
WP_DEBUG_LOG=false
WP_DEBUG_DISPLAY=false

# Database (for local development)
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PREFIX=wp_

# Security Keys (generate from https://api.wordpress.org/secret-key/1.1/salt/)
AUTH_KEY='put your unique phrase here'
SECURE_AUTH_KEY='put your unique phrase here'
LOGGED_IN_KEY='put your unique phrase here'
NONCE_KEY='put your unique phrase here'
AUTH_SALT='put your unique phrase here'
SECURE_AUTH_SALT='put your unique phrase here'
LOGGED_IN_SALT='put your unique phrase here'
NONCE_SALT='put your unique phrase here'

# API Keys (if needed)
GOOGLE_ANALYTICS_ID=
FACEBOOK_PIXEL_ID=
GOOGLE_MAPS_API_KEY=

# SMTP Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@your-domain.com
SMTP_FROM_NAME=Tetradkata

# Payment Gateways (optional)
VIVA_MERCHANT_ID=
VIVA_API_KEY=
VIVA_CLIENT_ID=
VIVA_CLIENT_SECRET=

# Shipping Providers (optional)
SPEEDY_USERNAME=
SPEEDY_PASSWORD=
ECONT_USERNAME=
ECONT_PASSWORD=

# Backup Configuration (optional)
BACKUP_EMAIL=admin@your-domain.com
BACKUP_FREQUENCY=daily

# CDN Configuration (optional)
CDN_URL=
CDN_ENABLED=false